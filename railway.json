{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "/src/**",
      "/pom.xml",
      "/Dockerfile",
      "/mvnw",
      "/mvnw.cmd",
      "/.mvn/**"
    ]
  },
  "deploy": {
    "healthcheckPath": "/actuator/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
