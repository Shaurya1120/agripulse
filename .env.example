GEMINI_API_KEY=replace-with-your-real-key
GEMINI_MODEL=gemini-2.0-flash-lite
PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Production database values
# Works with Neon/Supabase URLs. A JDBC URL also works.
DATABASE_URL=postgresql://user:password@host:5432/agripulse?sslmode=require
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Optional future storage provider values for file uploads
STORAGE_PROVIDER=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_STORAGE_BUCKET=agripulse-assets
SUPABASE_SERVICE_ROLE_KEY=replace-me
CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me
